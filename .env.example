# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Subscription prices — recurring, "All shows" access
STRIPE_PRICE_WEEKLY=          # $2.99 / week (recurring)
STRIPE_PRICE_MONTHLY=         # $5.99 / month (recurring, "Most Popular")
# One-time series unlock — grants permanent access to one series' episodes
STRIPE_PRICE_SERIES_UNLOCK=   # $2.99 one-time (payment)

# Paywall copy (optional, client-visible). Keep price in sync with the Stripe price above.
NEXT_PUBLIC_SERIES_UNLOCK_PRICE=2.99
NEXT_PUBLIC_SOCIAL_PROOF_COUNT=1300

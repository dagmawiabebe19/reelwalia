# Admin access (comma-separated emails)
ADMIN_EMAILS=dagmawiabebe19@gmail.com

# Creator submissions (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=ReelWalia Submissions <onboarding@resend.dev>
